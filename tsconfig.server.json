{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist/server",
    "noEmit": false,
    "allowJs": false,
    "allowImportingTsExtensions": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["server.ts"]
}
