# GEMINI_API_KEY: Optional.
# Set it only when this workspace uses Gemini-powered features.
# Store it in `.env.local` for local development or in your hosting secret manager for production.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Required in production.
# The public base URL for this app/workspace.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://example.com"

# PORT: Required in production.
# The internal Node.js port used by the production server.
# On aaPanel, set this to the port configured in the Node Project.
PORT="3000"

# HOST: Required on aaPanel/VPS.
# The network interface the Node.js server listens on.
# Keep `0.0.0.0` on VPS deployments so the reverse proxy can reach it.
HOST="0.0.0.0"
