{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile, mainly for admin role control.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Portfolio projects displayed on the public site.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "color": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "slug", "description", "category", "image"]
    },
    "Blog": {
      "title": "Blog",
      "description": "Blog articles published on the site.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "slug", "excerpt", "content", "category", "createdAt"]
    },
    "Skill": {
      "title": "Skill",
      "description": "Development skills and proficiency.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "proficiency": { "type": "number" },
        "icon": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "category", "proficiency"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "budget": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user roles and profiles."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores portfolio projects."
    },
    "/blogs/{blogId}": {
      "schema": { "$ref": "#/entities/Blog" },
      "description": "Stores blog posts."
    },
    "/skills/{skillId}": {
      "schema": { "$ref": "#/entities/Skill" },
      "description": "Stores developer skills."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores contact messages."
    }
  }
}
