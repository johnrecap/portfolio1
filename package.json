{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "preview": "npm run build && npm run start",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "lint": "tsc --noEmit",
    "test:content": "tsx --test src/lib/content-utils.test.ts src/lib/project-utils.test.ts src/lib/content-hub.test.ts src/lib/media.test.ts",
    "test:admin": "tsx --test src/lib/admin/auth.test.ts src/lib/admin/defaults.test.ts src/lib/admin/page-config.test.ts src/lib/admin/page-content.test.ts src/lib/admin/platform-settings.test.ts src/lib/admin/section-registry.test.ts src/lib/admin/settings.test.ts",
    "test:firestore": "tsx --test src/hooks/useFirestore.test.ts src/hooks/public-firestore.test.ts",
    "test:locales": "tsx --test src/locales/dashboard-locales.test.ts",
    "test": "npm run test:content && npm run test:admin && npm run test:firestore && npm run test:locales",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/server/server.js')\"",
    "i18n:check": "node scripts/i18n/locale-tools.mjs check",
    "i18n:fix:ar": "node scripts/i18n/locale-tools.mjs fix-ar"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
